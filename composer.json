{
  "name": "martinjuul/baander",
  "type": "project",
  "license": "GPL-3.0-only",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": ">=8.5",
    "ext-ctype": "*",
    "ext-fileinfo": "*",
    "ext-gd": "*",
    "ext-iconv": "*",
    "ext-inotify": "*",
    "ext-openssl": "*",
    "ext-pcntl": "*",
    "ext-pdo": "*",
    "ext-pgsql": "*",
    "ext-posix": "*",
    "ext-redis": "*",
    "ext-sockets": "*",
    "ext-swoole": "*",
    "cweagans/composer-patches": "^2.0",
    "doctrine/doctrine-bundle": "^3.2.2",
    "doctrine/doctrine-migrations-bundle": "^4.0.0",
    "doctrine/orm": "^3.6.6",
    "dragonmantank/cron-expression": "^3.6",
    "erusev/parsedown": ">=1.8",
    "hidehalo/nanoid-php": "^2.0",
    "league/oauth2-server": "^9.3",
    "minishlink/web-push": "^10.0.3",
    "nelmio/api-doc-bundle": "^5.10.2",
    "nelmio/cors-bundle": "^2.6.1",
    "nyholm/psr7": "^1.8.2",
    "open-telemetry/api": ">=1.9",
    "open-telemetry/context": ">=1.5",
    "open-telemetry/exporter-otlp": ">=1.4",
    "open-telemetry/sdk": ">=1.14",
    "pentatrion/vite-bundle": "^8.2.4",
    "predis/predis": "^3.4.2",
    "ramsey/uuid": "^4.9.2",
    "spomky-labs/cbor-php": "^3.2.3",
    "spomky-labs/otphp": "^11.4.2",
    "swoole-bundle/swoole-bundle": "@dev",
    "swoole-bundle/z-engine": "dev-8.5_fixes as 8.5.2",
    "swoole/ide-helper": "@dev",
    "symfony/asset": "8.0.*",
    "symfony/cache": "8.0.*",
    "symfony/console": "8.0.*",
    "symfony/dotenv": "8.0.*",
    "symfony/expression-language": "8.0.*",
    "symfony/flex": "^2.10",
    "symfony/framework-bundle": "8.0.*",
    "symfony/http-client": "8.0.*",
    "symfony/mailer": "8.0.*",
    "symfony/messenger": "8.0.*",
    "symfony/monolog-bundle": "^4.0.2",
    "symfony/notifier": "8.0.*",
    "symfony/psr-http-message-bridge": "^7.4.8",
    "symfony/rate-limiter": "8.0.*",
    "symfony/redis-messenger": "8.0.*",
    "symfony/runtime": "8.0.*",
    "symfony/security-bundle": "8.0.*",
    "symfony/serializer": "8.0.*",
    "symfony/translation": "8.0.*",
    "symfony/twig-bundle": "8.0.*",
    "symfony/uid": "8.0.*",
    "symfony/validator": "8.0.*",
    "symfony/workflow": "8.0.*",
    "symfony/yaml": "8.0.*",
    "tsduck/php": "@dev",
    "upscale/swoole-reflection": "dev-reflection-fix as 3.3.0",
    "web-auth/webauthn-lib": "^5.3.3"
  },
  "require-dev": {
    "baander/phpstan-rules": "@dev",
    "deptrac/deptrac": "^4.6.1",
    "phpstan/phpstan": "^2.1.55",
    "phpstan/phpstan-doctrine": "^2.0.22",
    "phpstan/phpstan-symfony": "^2.0.18",
    "brianium/paratest": "^7.22.4",
    "dama/doctrine-test-bundle": "dev-master",
    "phpunit/phpunit": "^13.1.11",
    "reliforp/reli-prof": "^0.12.0",
    "symfony/browser-kit": "8.0.*",
    "symfony/phpunit-bridge": "8.0.*",
    "symfony/stopwatch": "8.0.*",
    "symfony/web-profiler-bundle": "8.0.*",
    "zenstruck/foundry": "^2.10.1"
  },
  "config": {
    "allow-plugins": {
      "cweagans/composer-patches": true,
      "php-http/discovery": true,
      "symfony/flex": true,
      "symfony/runtime": true,
      "tbachert/spi": true
    },
    "bump-after-update": true,
    "sort-packages": true,
    "platform": {
      "ext-swoole": "6.2.0"
    }
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "replace": {
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-iconv": "*",
    "symfony/polyfill-php72": "*",
    "symfony/polyfill-php73": "*",
    "symfony/polyfill-php74": "*",
    "symfony/polyfill-php80": "*",
    "symfony/polyfill-php81": "*",
    "symfony/polyfill-php82": "*",
    "symfony/polyfill-php83": ">=1.31.0",
    "symfony/polyfill-php84": "*"
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ],
    "deptrac": "deptrac analyse",
    "deptrac:baseline": "deptrac analyse --formatter=baseline --output=deptrac.baseline.yaml",
    "deptrac:graph": "deptrac analyse --formatter=graphviz --output=deptrac-graph.dot",
    "openapi": "./bin/console app:export-openapi-spec  --format=json --output=openapi.json"
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "8.0.*"
    },
    "patches": {
      "swoole-bundle/z-engine": {
        "PHP 8.5 ZTS init + typed properties": "patches/swoole-bundle-z-engine-php85-zts-init.patch"
      }
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "./packages/baander-phpstan-rules",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "./packages/swoole-bundle",
      "options": {
        "symlink": true
      }
    },
    {
      "name": "swoole-bundle/swoole-bundle",
      "type": "git",
      "url": "https://github.com/symfony-swoole/swoole-bundle.git"
    },
    {
      "type": "git",
      "url": "https://github.com/Rastusik/swoole-reflection.git"
    },
    {
      "type": "path",
      "url": "./packages/tsduck-php-ffi",
      "options": {
        "symlink": true
      }
    }
  ]
}
