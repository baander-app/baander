{
  "name": "@baander/dpop",
  "version": "0.0.1",
  "description": "DPoP (RFC 9449) proof generation for Baander apps",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@baander/shared": "*"
  },
  "devDependencies": {
    "tsup": "8.3.5",
    "typescript": "5.7.3"
  }
}
