{
  "name": "@baander/web",
  "license": "GPL-3.0-only",
  "private": true,
  "version": "0.0.0",
  "packageManager": "yarn@4.14.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate": "orval",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "e2e": "playwright test --headed -c tests/e2e/playwright.config.ts",
    "e2e:headless": "playwright test -c tests/e2e/playwright.config.ts",
    "e2e:ui": "playwright test --ui -c tests/e2e/playwright.config.ts",
    "e2e:debug": "playwright test --debug -c tests/e2e/playwright.config.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/kanit": "^5.2.8",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@fontsource/pretendard": "^5.2.5",
    "@lucide/lab": "^0.1.2",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-virtual": "^3.13.26",
    "assjs": "^0.1.7",
    "axios": "^1.16.1",
    "blurhash": "^2.0.5",
    "cmdk": "^1.1.1",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "libpgs": "^0.8.1",
    "lucide": "^1.16.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.1",
    "sonner": "^2.0.7",
    "styled-components": "^6.4.2",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "orval": "^8.12.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-symfony": "^8.2.4",
    "vitest": "^4.1.7"
  }
