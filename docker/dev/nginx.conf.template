map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream upstream_backend_php {
    server app:9501;
    keepalive 64;
}

server {
    listen 80;
    server_name ${SERVER_NAME};

    location / {
        return 307 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    ssl_certificate     /etc/nginx/certificates/cert.pem;
    ssl_certificate_key /etc/nginx/certificates/key.pem;
    server_name ${SERVER_NAME};

    charset utf-8;
    server_tokens off;

    # Media uploads (audio, video, images) can be up to 100MB
    client_max_body_size 100m;

    # SSL hardening
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # Security headers
    add_header X-Content-Type-Options nosniff always;
    add_header Strict-Transport-Security "max-age=63072000" always;

    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log;

    # --- Gzip compression for text-based responses ---

    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 4;
    gzip_min_length 256;
    gzip_types
        application/json
        application/vnd.apple.mpegurl
        application/dash+xml
        application/xml
        text/plain
        text/css
        text/javascript
        application/javascript
        image/svg+xml;

    # --- Shared proxy headers (inherited by all location blocks) ---

    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header Http_Host $http_host;
    proxy_set_header Scheme $scheme;
    proxy_set_header SERVER_PORT $server_port;
    proxy_set_header REMOTE_ADDR $remote_addr;

    # Connection: keep-alive for upstream reuse. Overridden in location /
    # for WebSocket/SSE upgrade support.
    proxy_set_header Connection '';

    # --- Deny hidden files (except .well-known) ---

    location ~ /\.(?!well-known).* {
        deny all;
    }

    # ============================================================
    # Streaming: HLS/DASH video segments
    # ============================================================

    # CMAF segments: small binary, bursty (player fetches every 2–6s per rendition)
    location ~ ^/api/stream/.+\.m4s$ {
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 4 256k;
        proxy_pass http://upstream_backend_php;
    }

    # CMAF init segment: small, hot on player startup
    location ~ ^/api/stream/.+/init\.mp4$ {
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 4 64k;
        proxy_pass http://upstream_backend_php;
    }

    # HLS manifests (.m3u8) and DASH manifests (.mpd): tiny text, re-fetched frequently
    location ~ ^/api/stream/.+\.(m3u8|mpd)$ {
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 2 4k;
        proxy_busy_buffers_size 4k;
        proxy_pass http://upstream_backend_php;
    }

    # ============================================================
    # Streaming: audio (music) with HTTP Range / seek support
    # ============================================================

    # /api/stream/track and /api/stream/media — BinaryFileResponse / StreamedResponse
    # with HTTP 206 Partial Content. No buffering: the app handles byte-range slicing
    # and 206 responses must pass through unmodified.
    location ~ ^/api/stream/(track|media)$ {
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_pass http://upstream_backend_php;
    }

    # ============================================================
    # Images: binary file delivery (long cache, small payloads)
    # ============================================================

    # /api/images/{publicId}/file — StreamedResponse, 30-day cache
    location ~ ^/api/images/[^/]+/file$ {
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 4 64k;
        proxy_pass http://upstream_backend_php;
    }

    # ============================================================
    # Everything else: API JSON, SSE, WebSocket
    # ============================================================

    location / {
        # Safe method filtering (replaces the if-block anti-pattern)
        limit_except GET POST HEAD OPTIONS PUT DELETE PATCH {
            deny all;
        }

        # Explicit proxy headers (override proxy_pass defaults)
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Override Connection for WebSocket/SSE upgrade support
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        # SSE: no buffering, long timeouts
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;

        proxy_pass http://upstream_backend_php;
    }
}
