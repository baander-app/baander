# Copy this file to .env and fill in the values:
#   cp .env.example .env

###> symfony/framework-bundle ###
APP_ENV=dev
# Comma-separated for live rotation: first is active, rest verify only.
# Example during rotation: APP_SECRET=new_secret,old_secret
# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=change_me_in_production
APP_URL=https://localhost
APP_DOMAIN=localhost
APP_NAME=Bånder
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=https://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://baander:baander@database:5432/baander?serverVersion=18&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=redis://default:${REDIS_PASSWORD}@redis:6379/messages
MESSENGER_CONSUMER_NAME=${HOSTNAME:-worker}
###< symfony/messenger ###

###> app ###
REDIS_URL=redis://default:${REDIS_PASSWORD}@redis:6379
# Optional in dev, required in production.
REDIS_PASSWORD=

# Auth - Passwords (Argon2id)
ARGON2ID_MEMORY_COST=65536
ARGON2ID_TIME_COST=4
ARGON2ID_THREAD_COST=3

PASSWORD_RESET_EXPIRE=60
PASSWORD_RESET_THROTTLE=60
PASSWORD_TIMEOUT=10800

# Token Binding
TOKEN_BINDING_MAX_IP_CHANGES=10
TOKEN_BINDING_CONCURRENT_IP_WINDOWS_SECONDS=300
TOKEN_BINDING_MAX_CONCURRENT_IPS=1
TOKEN_BINDING_MIN_IP_CHANGE_INTERVAL_MINUTES=5

# Scanner Security Settings
SCANNER_ALLOWED_PATHS="/home,/media,/mnt,/Users,/Volumes"
SCANNER_MAX_AUDIO_SIZE_MB=500
SCANNER_MAX_VIDEO_SIZE_MB=5000
SCANNER_MAX_LYRICS_SIZE_MB=1
SCANNER_MAX_IMAGE_SIZE_MB=10
SCANNER_MAX_SUBTITLE_SIZE_MB=1
SCANNER_MAX_TOTAL_FILES=100000
SCANNER_MAX_DIRECTORY_DEPTH=20
SCANNER_FILE_TIMEOUT=30
SCANNER_DIR_TIMEOUT=300
SCANNER_VALIDATE_MAGIC_BYTES=true
SCANNER_ALLOW_MIME_MISMATCH=false
SCANNER_SANITIZE_METADATA=true
SCANNER_MAX_TITLE_LENGTH=255
SCANNER_MAX_ARTIST_LENGTH=255
SCANNER_MAX_ALBUM_LENGTH=255
SCANNER_MAX_GENRE_LENGTH=100
SCANNER_MAX_COMMENT_LENGTH=1000
SCANNER_MAX_LYRICS_LENGTH=50000

# Local Network Discovery
DISCOVERY_ENABLED=true
DISCOVERY_PORT=41234
DISCOVERY_SERVER_NAME="Bånder"

# Mail (required for email features)
MAILER_DSN=smtp://localhost:1025
MAIL_FROM_ADDRESS="noreply@localhost"
MAIL_FROM_NAME="Bånder"

# Web Push (VAPID) — generate keys with: php bin/console app:generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# OAuth 2.0 — generate keys with: php bin/console app:auth:setup-clients
OAUTH_PRIVATE_KEY_PATH=%kernel.project_dir%/config/secrets/oauth/private.key
OAUTH_PUBLIC_KEY_PATH=%kernel.project_dir%/config/secrets/oauth/public.key
# Required in production. Generate with:
#   php -r "echo Defuse\Crypto\Key::create()->saveToAsciiSafeString();"
# WARNING: Leaving this empty causes a different encryption key to be generated per
# Swoole worker process. This silently breaks the authorization code flow in multi-worker
# setups because the code exchanged in one worker cannot be decrypted by another.
# Always set a fixed key in production.
OAUTH_ENCRYPTION_KEY=

# External APIs — leave empty to disable
MUSICBRAINZ_APP_NAME=Bånder
MUSICBRAINZ_VERSION=1.0.0
MUSICBRAINZ_CONTACT=noreply@localhost
DISCOGS_TOKEN=
LASTFM_API_KEY=
LASTFM_API_SECRET=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
TASTE_DIVE_API_KEY=

# Media Storage
MEDIA_STORAGE_PATH=/storage/media
CONVERT_STORAGE_PATH=/storage/conversions
FFMPEG_PATH=/usr/local/bin/ffmpeg
FFPROBE_PATH=/usr/local/bin/ffprobe
###< app ###

###> transcode/stream-auth ###
STREAM_URL_HMAC_SECRET=change-me-to-a-random-64-char-secret-in-production
###< transcode/stream-auth ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

AUTH_SPA_CLIENT_ID=baander_dev_spa_00001
AUTH_ELECTRON_CLIENT_ID=baander_dev_elc_00001

JOB_MONITOR_MAX_PAYLOAD_SIZE=20000000
