     /**
+     * Initializes executor/compiler globals from thread-local storage (ZTS builds).
+     *
+     * In ZTS PHP, executor_globals and compiler_globals are stored in thread-local
+     * storage accessed via tsrm_get_ls_cache() + an offset. The struct layouts are
+     * identical to NTS — only the access path differs.
+     */
+    private static function initZts(FFI $engine): void
+    {
+        // In ZTS builds, executor/compiler globals are stored directly in
+        // thread-local storage at byte offsets accessed via tsrm_get_ls_cache().
+        // ZEND_TSRMG_FAST(offset, type, element) = ((type*)((char*)tls + offset))->element
+
+        $zts = FFI::cdef('
+            typedef unsigned long size_t;
+            void *dlopen(const char *filename, int flags);
+            void *dlsym(void *handle, const char *symbol);
+        ');
+
+        $rtldDefault = $zts->dlopen(null, 0);
+
+        // Load tsrm_get_ls_cache function pointer
+        $getLsCacheFn = $zts->cast('void *(*)(void)', $zts->dlsym($rtldDefault, 'tsrm_get_ls_cache'));
+        $tls = $getLsCacheFn();
+        if ($tls === null) {
+            throw new \RuntimeException('tsrm_get_ls_cache() returned null.');
+        }
+
+        // Extract the TLS pointer value as a PHP integer.
+        // We use a struct holder to bridge cross-FFI CData extraction (PHP 8.5 issue).
+        $holder = $zts->new('struct { void *ptr; }');
+        $holder->ptr = $tls;
+        $tlsAddress = (int)$zts->cast('size_t *', FFI::addr($holder->ptr))[0];
+
+        // Read the byte offsets from the PHP binary's exported symbols
+        $egOffset = (int)$zts->cast('size_t *', $zts->dlsym($rtldDefault, 'executor_globals_offset'))[0];
+        $cgOffset = (int)$zts->cast('size_t *', $zts->dlsym($rtldDefault, 'compiler_globals_offset'))[0];
+
+        // The EG/CG structs are stored directly at tls + offset (no indirection)
+        $egAddress = $tlsAddress + $egOffset;
+        $cgAddress = $tlsAddress + $cgOffset;
+
+        // Cast integer addresses to typed struct pointers in the engine FFI scope
+        $egPtr = $engine->cast('zend_executor_globals *', $egAddress);
+        $cgPtr = $engine->cast('zend_compiler_globals *', $cgAddress);
+
+        self::$executor = new Executor($egPtr);
+        self::$compiler = new Compiler($cgPtr);
+
+        // module_registry is a separate global (not part of EG in PHP 8.5)
+        $moduleRegistryAddr = $zts->dlsym($rtldDefault, 'module_registry');
+        $moduleRegistryPtr = $zts->cast('void **', $moduleRegistryAddr);
+        self::$modules = new HashTable(Core::addr($moduleRegistryPtr[0]));
+
+        // Keep $zts alive to prevent CData chain invalidation
+        self::$ztsHelper = $zts;
+    }
