{
  "name": "baander",
  "version": "1.0.0",
  "private": true,
  "description": "Bånder Desktop — a fast, privacy‑respecting music player for your self‑hosted Bånder server.",
  "author": "Martin Christiansen <code@juul.xyz>",
  "repository": {
    "type": "git",
    "url": "https://github.com/baander-app/baander.git"
  },
  "homepage": "https://github.com/baander-app/",
  "license": "Apache-2.0",
  "type": "module",
  "main": "electron/dist-electron/main/index.js",
  "scripts": {
    "tsc": "tsc --noEmit --skipLibCheck",
    "clean": "rimraf public/build",
    "build": "yarn clean && tsc --noEmit --skipLibCheck || true && vite build",
    "dev": "yarn clean && vite",
    "generate-api-client": "npx orval --config orval.config.cjs && node node_modules/.bin/tsx codemods/orvalAwaitedFix.ts",
    "electron-rebuild": "electron-rebuild -f -w @napi-rs/keyring",
    "dev:electron": "vite --config electron/config/vite.config.mts",
    "build:electron": "vite build --config electron/config/vite.config.mts",
    "dist:electron": "yarn build:electron && electron-builder -c electron-builder.yml",
    "dist:win": "yarn build:electron && electron-builder -c electron-builder.yml --win",
    "dist:linux": "yarn build:electron && electron-builder -c electron-builder.yml --linux",
    "dist:mac": "yarn build:electron && electron-builder -c electron-builder.yml --mac",
    "dist:all": "yarn build:electron && electron-builder -c electron-builder.yml -w -l -m",
    "build:wasm": "tsx scripts/build-wasm.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
